# 改行正規化: 全テキストを LF に固定。
# Windows の core.autocrlf=true 下でも checkout 時に CRLF へ変換させない。
# 共有セットは現状すべて LF であり、shell スクリプト(setup.sh)は CRLF 化すると
# git-bash / WSL で壊れるため明示的に LF を保証する。
* text=auto eol=lf

# shell スクリプトは LF 必須(明示)。
*.sh text eol=lf

# バイナリは変換禁止。
*.xlsx binary
*.db binary
*.png binary
*.gz binary
