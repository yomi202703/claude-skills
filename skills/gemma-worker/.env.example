# Template for gemma-worker skill credentials.
# Copy to .env (gitignored) and fill in real values, then `source .env`
# before invoking the skill.
#
#   cp .env.example .env
#   ${EDITOR:-vim} .env
#   source .env

export WORKER_LLM_BASE_URL="https://<your-openai-compat-host>/v1"
export WORKER_LLM_API_KEY="<your-api-key>"
export WORKER_LLM_MODEL="<model-id>"          # e.g. gemma-4-31B-it, qwen2.5-coder:32b
export WORKER_LLM_PROVIDER="gemma"             # gemma | openai | anthropic | ollama | vllm
